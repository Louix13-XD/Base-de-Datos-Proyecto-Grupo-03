        <a href="/admin/proveedores" class="nav-link-admin <%= title.includes('Proveedores') ? 'active' : '' %>">
            <i class="bi bi-shop me-3"></i> Proveedores
        </a>
        <a href="/admin/abastecimiento" class="nav-link-admin <%= title.includes('Abastecimiento') ? 'active' : '' %>">
            <i class="bi bi-journal-plus me-3"></i> Abastecimiento
        </a>
        <a href="/admin/personal" class="nav-link-admin admin-only <%= title.includes('Personal') || title.includes('Personal') ? 'active' : '' %>">
            <i class="bi bi-person-badge me-3"></i> Usuarios
        </a>
        <a href="/admin/usuarios" class="nav-link-admin admin-only <%= title.includes('Clientes') || title.includes('Usuarios') ? 'active' : '' %>">
            <i class="bi bi-people me-3"></i> Clientes
        </a>
        <a href="/admin/ventas" class="nav-link-admin <%= title.includes('Ventas') ? 'active' : '' %>">
            <i class="bi bi-cart-check me-3"></i> Ventas
        </a>
        <a href="/admin/mermas" class="nav-link-admin <%= title.includes('Mermas') ? 'active' : '' %>">
            <i class="bi bi-exclamation-octagon me-3"></i> Mermas
        </a>
        <a href="/admin/logistica" class="nav-link-admin <%= title.includes('Logística') ? 'active' : '' %>">
            <i class="bi bi-truck me-3"></i> Logística

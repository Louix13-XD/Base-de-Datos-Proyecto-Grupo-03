<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; }
        .admin-sidebar { width: 250px; height: 100vh; position: fixed; background: #212529; color: white; }
        .admin-content { margin-left: 250px; padding: 30px; }
        .nav-link-admin { color: rgba(255,255,255,0.7); padding: 15px 25px; display: block; text-decoration: none; border-left: 4px solid transparent; }
        .nav-link-admin:hover, .nav-link-admin.active { color: #ffc107; background: rgba(255,193,7,0.1); border-left-color: #ffc107; }
        .card-merma { border-left: 5px solid #dc3545; transition: transform 0.2s; }
        .card-merma:hover { transform: translateY(-5px); }
    </style>
    <link rel="icon" type="image/png" href="/img/logo_ferreteria.png">
</head>
<body>

    <%- include('admin_sidebar') %>

    <main class="admin-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">Gestión de Mermas</h2>
                <p class="text-muted mb-0">Control de pérdidas físicas por daño, roturas, vencimientos o robo.</p>
            </div>
            <button class="btn btn-danger fw-bold px-4 py-2 rounded-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalNuevaMerma">
                <i class="bi bi-exclamation-octagon me-2"></i>Reportar Merma
            </button>
        </div>

        <div class="row" id="mermas-container">
            <!-- Dinámico -->
            <div class="col-12 text-center py-5">
                <div class="spinner-border text-danger"></div>
                <p class="mt-2">Cargando registros de mermas...</p>
            </div>
        </div>
    </main>

    <!-- Modal Reportar Nueva Merma -->
    <div class="modal fade" id="modalNuevaMerma" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-danger text-white py-3">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Reportar Merma de Almacén</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="formNuevaMerma">
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Producto</label>
                            <select class="form-select" id="merma-producto" required>
                                <option value="">Seleccione un producto...</option>
                                <!-- Carga dinámica de productos -->
                            </select>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Cantidad a Dar de Baja</label>
                                <input type="number" class="form-control" id="merma-cantidad" min="1" required placeholder="Ej: 5">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Tipo de Merma</label>
                                <select class="form-select" id="merma-tipo" required>
                                    <option value="">Seleccione...</option>
                                    <option value="Rotura/Daño">Rotura / Daño</option>
                                    <option value="Vencido">Producto Vencido</option>
                                    <option value="Defecto de Fábrica">Defecto de Fábrica</option>
                                    <option value="Robo/Pérdida">Robo / Pérdida</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold small">Detalles / Observaciones</label>
                            <textarea class="form-control" id="merma-descripcion" rows="3" placeholder="Ej: Bolsa rota al mover el montacargas en el pasillo 2" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-danger w-100 fw-bold py-2 shadow-sm">REGISTRAR PÉRDIDA Y DISMINUIR STOCK</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        let productosGlobal = [];

        document.addEventListener('DOMContentLoaded', () => {
            const currentUser = JSON.parse(localStorage.getItem('currentUser'));
            if (!currentUser || currentUser.role === 'Cliente' || currentUser.role === 'client') {
                window.location.href = '/login';
                return;
            }

            renderMermas();
            cargarProductos();
        });

        async function cargarProductos() {
            try {
                const res = await fetch('/api/productos');
                const data = await res.json();
                if (data.success) {
                    productosGlobal = data.products;
                    const select = document.getElementById('merma-producto');
                    select.innerHTML = '<option value="">Seleccione un producto...</option>' +
                        productosGlobal.map(p => `<option value="${p.id}">${p.nombre} (${p.marca}) - Stock: ${p.stock}</option>`).join('');
                }
            } catch (err) {
                console.error('Error al cargar productos en mermas:', err);
            }
        }

        async function renderMermas() {
            const container = document.getElementById('mermas-container');
            try {
                const res = await fetch('/api/mermas');
                const data = await res.json();

                if (data.success) {
                    const mermas = data.mermas;
                    container.innerHTML = '';

                    if (mermas.length === 0) {
                        container.innerHTML = `
                            <div class="col-12 text-center py-5">
                                <i class="bi bi-check-circle text-success display-1"></i>
                                <h4 class="mt-3 fw-bold">Sin mermas registradas</h4>
                                <p class="text-muted">No se han reportado productos defectuosos o pérdidas recientemente.</p>
                            </div>`;
                        return;
                    }

                    mermas.forEach(merma => {
                        const date = new Date(merma.fecha_compra).toLocaleDateString('es-PE', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
                        
                        container.innerHTML += `
                            <div class="col-md-6 mb-4">
                                <div class="card border-0 shadow-sm rounded-4 card-merma h-100 p-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="badge bg-danger bg-opacity-10 text-danger fw-bold text-uppercase">${merma.tipo_merma}</span>
                                        <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>${date}</span>
                                    </div>
                                    <h6 class="fw-bold text-dark mb-0">${merma.nombre_producto}</h6>
                                    <small class="text-muted d-block mb-2">Marca: ${merma.marca || '---'} | Cantidad perdida: ${merma.cantidad}</small>
                                    
                                    <h6 class="fw-bold text-secondary mb-1 small">OBSERVACIONES:</h6>
                                    <p class="mb-3 p-2 bg-light rounded italic small text-dark">"${merma.motivo_falla || 'Sin detalles'}"</p>
                                    
                                    <div class="border-top pt-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <small class="text-muted d-block">Reportado por:</small>
                                                <span class="fw-semibold small">${merma.cliente_nombre}</span>
                                            </div>
                                            <div class="text-end">
                                                <small class="text-muted d-block">Pérdida Incurrida:</small>
                                                <span class="fw-bold text-danger">S/ ${parseFloat(merma.subtotal).toFixed(2)}</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                }
            } catch (error) {
                console.error(error);
                container.innerHTML = '<p class="text-danger text-center py-5">Error al cargar datos de mermas.</p>';
            }
        }

        document.getElementById('formNuevaMerma').addEventListener('submit', async function(e) {
            e.preventDefault();
            const currentUser = JSON.parse(localStorage.getItem('currentUser'));
            const btnSubmit = this.querySelector('button[type="submit"]');
            btnSubmit.disabled = true;

            const payload = {
                id_producto: parseInt(document.getElementById('merma-producto').value),
                cantidad: parseInt(document.getElementById('merma-cantidad').value),
                tipo_merma: document.getElementById('merma-tipo').value,
                descripcion: document.getElementById('merma-descripcion').value.trim(),
                id_usuario: currentUser.id
            };

            try {
                const res = await fetch('/api/mermas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();

                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('modalNuevaMerma')).hide();
                    this.reset();
                    Swal.fire({
                        title: '¡Merma Registrada!',
                        text: 'La pérdida ha sido registrada y se ha descontado el stock físico del almacén.',
                        icon: 'success'
                    });
                    renderMermas();
                    cargarProductos(); // Recargar stock actual en el selector
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            } catch (err) {
                Swal.fire('Error', 'Error de red al procesar la merma.', 'error');
            } finally {
                btnSubmit.disabled = false;
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
